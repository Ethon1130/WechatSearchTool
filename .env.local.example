# Leave this unset if you only need raw extraction.
# Create a DeepSeek API key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override the DeepSeek-compatible endpoint.
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Optional: override the model name. Default is deepseek-chat.
# DEEPSEEK_MODEL=deepseek-chat

# Optional: use your own logged-in WeChat web cookie to improve public account
# homepage history discovery. Only requests to mp.weixin.qq.com receive it.
# Leave empty unless you understand the privacy and access implications.
# WECHAT_COOKIE=pgv_pvid=...; wxuin=...; rewardsn=...
